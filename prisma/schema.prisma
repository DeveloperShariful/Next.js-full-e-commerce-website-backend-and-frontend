  gmcAttributeMapping       Json?    

  // 6. Sync Preferences
  gmcContentApiEnabled      Boolean  @default(false)
  gmcAutoSyncShipping       Boolean  @default(true)  // ওয়েবসাইটের শিপিং রুল গুগলে পাঠানো হবে কিনা
  gmcAutoSyncTaxes          Boolean  @default(true)

  // ==========================================
  // 🚀 NEW: GOOGLE ADS INTEGRATION (WooCommerce Style)
  // ==========================================
  googleAdsAccountId        String?  // এডস একাউন্ট আইডি (e.g. 556-643-3646)
  googleAdsAccountName      String?  
