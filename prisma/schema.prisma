  googleAdsLinkStatus       String?  @default("UNLINKED") // UNLINKED, PENDING_APPROVAL, LINKED, FAILED
  googleAdsConversionId     String?  // গুগল ট্র্যাকিং আইডি (e.g., AW-109283746)
  googleAdsConversionLabel  String?  // পারচেজ কনভার্সন ট্র্যাকিং লেবেল (e.g., abCDefGhIJKlMnOpqR)
  googleAdsEnhancedConversionsEnabled Boolean @default(false) // এনহ্যান্সড ট্র্যাকিং এনাবল করার জন্য

  
  // ==========================================
  // 3. Facebook / Meta Pixel & CAPI
  // ==========================================
  fbEnabled                 Boolean  @default(false)
  fbPixelId                 String?
  fbAccessToken             String?  @db.Text
  fbTestEventCode           String?
  fbDomainVerification      String?
