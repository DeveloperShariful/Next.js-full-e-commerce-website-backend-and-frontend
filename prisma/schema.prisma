model Analytics {
  id                 String   @id @default(uuid())
  date               DateTime @default(now()) @db.Date // প্রতিদিনের জন্য একটি রো তৈরি হবে

  // --- Sales Metrics (WooCommerce Overview) ---
  grossSales         Decimal  @default(0) @db.Decimal(12, 2) // ট্যাক্স, শিপিং, ডিসকাউন্ট বাদে অরিজিনাল দাম
  netSales           Decimal  @default(0) @db.Decimal(12, 2) // ডিসকাউন্ট ও রিফান্ড বাদ দেওয়ার পর প্রকৃত সেল
  totalTax           Decimal  @default(0) @db.Decimal(12, 2) // ওই দিন কত টাকা ট্যাক্স আসল
  totalShipping      Decimal  @default(0) @db.Decimal(12, 2) // ওই দিন শিপিং বাবদ কত টাকা আসল
  totalDiscounts     Decimal  @default(0) @db.Decimal(12, 2) // ওই দিন কত টাকার কুপন/ডিসকাউন্ট দেওয়া হলো
  totalRefunds       Decimal  @default(0) @db.Decimal(12, 2) // ওই দিন কত টাকা রিফান্ড করা হলো

  // --- Order & Item Metrics ---
  totalOrders        Int      @default(0) // ওই দিনের মোট সফল অর্ডার
  productsSold       Int      @default(0) // মোট কত পিস প্রোডাক্ট বিক্রি হলো
  variationsSold     Int      @default(0) // এর মধ্যে কতগুলো ভ্যারিয়েশন ছিল

  // --- Customer Metrics (Shopify Style) ---
  newCustomers       Int      @default(0) // যারা জীবনে প্রথমবার অর্ডার করল
  returningCustomers Int      @default(0) // যারা আগেও কিনেছে, আজ আবার কিনল

  // --- Cart & Checkout Metrics ---
  abandonedCheckouts Int      @default(0) // কতজন পেমেন্ট পেজ থেকে চলে গেছে
  recoveredCheckouts Int      @default(0) // কতজন ইমেইল পেয়ে আবার এসে পেমেন্ট করেছে

  // --- Traffic Metrics (Redis থেকে দিনশেষে আপডেট হবে) ---
  totalVisitors      Int      @default(0) // ইউনিক ইউজার
  totalPageViews     Int      @default(0) // মোট পেজ ভিউ

  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now()) @updatedAt

  @@unique([date])
  @@index([date, netSales])
}

